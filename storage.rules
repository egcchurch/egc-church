rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── Helpers ──────────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isMember() {
      return isSignedIn() &&
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.membership == 'member';
    }

    function isAdminUser() {
      return isSignedIn() &&
        (request.auth.token.superadmin == true ||
         (request.auth.token.perms is list && request.auth.token.perms.size() > 0));
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isValidImage() {
      return request.resource.contentType.matches('image/.*')
        && request.resource.size < 5 * 1024 * 1024; // 5MB max
    }

    function isValidAudio() {
      return request.resource.contentType.matches('audio/.*')
        && request.resource.size < 100 * 1024 * 1024; // 100MB max
    }

    function isValidPDF() {
      return request.resource.contentType == 'application/pdf'
        && request.resource.size < 20 * 1024 * 1024; // 20MB max
    }

    // ── Profile photos ────────────────────────────────────────────────────
    match /users/{uid}/photo {
      allow read: if isSignedIn();
      allow write: if isOwner(uid) && isValidImage();
    }

    // ── Sermon audio & notes (PDF) ────────────────────────────────────────
    match /sermons/{sermonId}/{fileName} {
      allow read: if true;
      allow write: if isAdminUser() && (isValidAudio() || isValidPDF());
    }

    // ── Gallery images ────────────────────────────────────────────────────
    match /gallery/{galleryId}/{fileName} {
      allow read: if true; // Audience check handled in Firestore
      allow write: if isAdminUser() && isValidImage();
    }

    // ── Sermon series cover images ────────────────────────────────────────
    match /series/{seriesId}/{fileName} {
      allow read: if true;
      allow write: if isAdminUser() && isValidImage();
    }

    // ── Music ─────────────────────────────────────────────────────────────
    match /music/{fileName} {
      allow read: if true;
      allow write: if isAdminUser() && isValidAudio();
    }

    match /music/covers/{fileName} {
      allow read: if true;
      allow write: if isAdminUser() && isValidImage();
    }

    // ── Blog & Events images ──────────────────────────────────────────────
    match /blog/{fileName} {
      allow read: if true;
      allow write: if isAdminUser() && isValidImage();
    }

    // Story cover and gallery images (nested under blog/{postId}/)
    match /blog/{postId}/{allPaths=**} {
      allow read: if true;
      allow write: if isAdminUser() && isValidImage();
    }

    match /events/{fileName} {
      allow read: if true;
      allow write: if isAdminUser() && isValidImage();
    }

    // ── Team photos ───────────────────────────────────────────────────────
    match /team/{fileName} {
      allow read: if true;
      allow write: if isAdminUser() && isValidImage();
    }

    // ── Site branding (logo) ──────────────────────────────────────────────
    match /branding/{fileName} {
      allow read: if true;
      allow write: if isSignedIn() && request.auth.token.superadmin == true && isValidImage();
    }
  }
}