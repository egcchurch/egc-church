rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── Helpers ──────────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isMember() {
      return isSignedIn() &&
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.membership == 'member';
    }

    function isEditor() {
      return isSignedIn() &&
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.adminRole in ['editor', 'superadmin'];
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isValidImage() {
      return request.resource.contentType.matches('image/.*')
        && request.resource.size < 5 * 1024 * 1024; // 5MB max
    }

    function isValidAudio() {
      return request.resource.contentType.matches('audio/.*')
        && request.resource.size < 100 * 1024 * 1024; // 100MB max
    }

    function isValidPDF() {
      return request.resource.contentType == 'application/pdf'
        && request.resource.size < 20 * 1024 * 1024; // 20MB max
    }

    // ── Profile photos ────────────────────────────────────────────────────
    match /users/{uid}/photo {
      allow read: if isSignedIn();
      allow write: if isOwner(uid) && isValidImage();
    }

    // ── Sermon audio ──────────────────────────────────────────────────────
    match /sermons/{fileName} {
      allow read: if true;
      allow write: if isEditor() && isValidAudio();
    }

    // ── Sermon notes (PDF) ────────────────────────────────────────────────
    match /sermon-notes/{fileName} {
      allow read: if true;
      allow write: if isEditor() && isValidPDF();
    }

    // ── Gallery images ────────────────────────────────────────────────────
    match /gallery/{galleryId}/{fileName} {
      allow read: if true; // Audience check handled in Firestore
      allow write: if isEditor() && isValidImage();
    }

    // ── Music ─────────────────────────────────────────────────────────────
    match /music/{fileName} {
      allow read: if true;
      allow write: if isEditor() && isValidAudio();
    }

    match /music/covers/{fileName} {
      allow read: if true;
      allow write: if isEditor() && isValidImage();
    }

    // ── Blog & Events images ──────────────────────────────────────────────
    match /blog/{fileName} {
      allow read: if true;
      allow write: if isEditor() && isValidImage();
    }

    match /events/{fileName} {
      allow read: if true;
      allow write: if isEditor() && isValidImage();
    }

    // ── Team photos ───────────────────────────────────────────────────────
    match /team/{fileName} {
      allow read: if true;
      allow write: if isEditor() && isValidImage();
    }
  }
}