rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // ── Helpers ──────────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isMember() {
      return isSignedIn() &&
        firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.membership == 'member';
    }

    function hasPermission(p) {
      return isSignedIn() &&
        (request.auth.token.superadmin == true ||
         (request.auth.token.perms is list && p in request.auth.token.perms));
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isValidImage() {
      return request.resource.contentType.matches('image/.*')
        && request.resource.size < 5 * 1024 * 1024; // 5MB max
    }

    function isValidAudio() {
      return request.resource.contentType.matches('audio/.*')
        && request.resource.size < 100 * 1024 * 1024; // 100MB max
    }

    function isValidDocument() {
      return request.resource.contentType in [
        'application/pdf',
        'application/msword',                                                       // .doc
        'application/vnd.openxmlformats-officedocument.wordprocessingml.document',  // .docx
        'application/vnd.ms-powerpoint',                                            // .ppt
        'application/vnd.openxmlformats-officedocument.presentationml.presentation' // .pptx
      ] && request.resource.size < 50 * 1024 * 1024; // 50MB max
    }

    // NOTE: `allow write` covers create/update/delete, but `request.resource` does not
    // exist on a delete request — any rule that calls isValidImage()/isValidAudio()/
    // isValidDocument() (which read request.resource.contentType) errors out and is
    // denied for deletes. Every block below splits "create, update" (validated) from
    // "delete" (auth-only) so deletes actually succeed. Confirmed via the Storage
    // emulator that the combined form silently failed every delete.

    // ── Profile photos ────────────────────────────────────────────────────
    match /users/{uid}/photo {
      allow read: if isSignedIn();
      allow create, update: if isOwner(uid) && isValidImage();
      allow delete: if isOwner(uid);
    }

    // ── Sermon audio (single file at this level) ───────────────────────────
    match /sermons/{sermonId}/{fileName} {
      allow read: if true;
      allow create, update: if hasPermission('sermons.manage') && (isValidAudio() || isValidDocument());
      allow delete: if hasPermission('sermons.manage');
    }

    // ── Sermon notes/materials (multiple files, nested under materials/) ───
    // {fileName} above only matches ONE path segment, so files uploaded one
    // level deeper (sermons/{id}/materials/{file}) need their own match block.
    match /sermons/{sermonId}/materials/{fileName} {
      allow read: if true;
      allow create, update: if hasPermission('sermons.manage') && isValidDocument();
      allow delete: if hasPermission('sermons.manage');
    }

    // ── Gallery images ────────────────────────────────────────────────────
    match /gallery/{galleryId}/{fileName} {
      allow read: if true; // Audience check handled in Firestore
      allow create, update: if hasPermission('gallery.manage') && isValidImage();
      allow delete: if hasPermission('gallery.manage');
    }

    // ── Sermon series cover images ────────────────────────────────────────
    match /series/{seriesId}/{fileName} {
      allow read: if true;
      allow create, update: if hasPermission('sermons.manage') && isValidImage();
      allow delete: if hasPermission('sermons.manage');
    }

    // ── Music ─────────────────────────────────────────────────────────────
    match /music/{fileName} {
      allow read: if true;
      allow create, update: if hasPermission('music.manage') && isValidAudio();
      allow delete: if hasPermission('music.manage');
    }

    match /music/covers/{fileName} {
      allow read: if true;
      allow create, update: if hasPermission('music.manage') && isValidImage();
      allow delete: if hasPermission('music.manage');
    }

    // ── Blog & Events images ──────────────────────────────────────────────
    match /blog/{fileName} {
      allow read: if true;
      allow create, update: if hasPermission('blog.manage') && isValidImage();
      allow delete: if hasPermission('blog.manage');
    }

    // Story cover and gallery images (nested under blog/{postId}/)
    match /blog/{postId}/{allPaths=**} {
      allow read: if true;
      allow create, update: if hasPermission('blog.manage') && isValidImage();
      allow delete: if hasPermission('blog.manage');
    }

    match /events/{fileName} {
      allow read: if true;
      allow create, update: if hasPermission('events.manage') && isValidImage();
      allow delete: if hasPermission('events.manage');
    }

    // ── Event registration proof-of-payment (Event Registration Phase B3) ──
    // Public create — no auth requirement, since a registrant may have no
    // account on this app at all (same posture as registerForEvent itself).
    // A scanned deposit slip is typically a phone photo or a PDF, hence both
    // validators; admin-only read/delete keeps other registrants' proof
    // private.
    match /events/{eventId}/registrations/{registrationId}/{fileName} {
      allow read: if hasPermission('events.manage');
      allow create: if isValidImage() || isValidDocument();
      allow update: if false;
      allow delete: if hasPermission('events.manage');
    }

    // ── Team photos ───────────────────────────────────────────────────────
    match /team/{fileName} {
      allow read: if true;
      allow create, update: if hasPermission('team.manage') && isValidImage();
      allow delete: if hasPermission('team.manage');
    }

    // ── Site branding (logo) ──────────────────────────────────────────────
    match /branding/{fileName} {
      allow read: if true;
      allow create, update: if isSignedIn() && request.auth.token.superadmin == true && isValidImage();
      allow delete: if isSignedIn() && request.auth.token.superadmin == true;
    }

    // ── Site media (general-purpose uploads, /admin/media.html) ───────────
    // Superadmin only — a general file dropbox, not scoped to one content
    // type, so it's gated tighter than the per-area paths above. Generous
    // size cap to comfortably cover a full sermon-length audio recording.
    match /site-media/{fileName} {
      allow read: if true;
      allow create, update: if isSignedIn() && request.auth.token.superadmin == true &&
        (isValidImage() || isValidDocument() ||
         (request.resource.contentType.matches('audio/.*') && request.resource.size < 150 * 1024 * 1024));
      allow delete: if isSignedIn() && request.auth.token.superadmin == true;
    }
  }
}
