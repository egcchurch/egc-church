rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isMember() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.membership == 'member';
    }

    // Permission checks use Firebase Auth custom claims set by syncUserClaims.
    function isSuperadmin() {
      return request.auth != null && request.auth.token.superadmin == true;
    }

    function hasPermission(p) {
      return isSuperadmin() ||
             (request.auth != null &&
              request.auth.token.perms is list &&
              p in request.auth.token.perms);
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // ── Users ─────────────────────────────────────────────────────────────────
    match /users/{uid} {
      allow read: if isOwner(uid) || isSuperadmin() || hasPermission('users.approve')
                  || (isMember() && resource.data.directoryVisible == true);
      allow create: if isOwner(uid);
      // isOwner: self-service profile fields (name, photo, privacy)
      // users.approve: set membership tier and membershipRequestedAt only
      // users.assign_roles: set roles/extraPermissions only (not isSuperadmin)
      // isSuperadmin: unrestricted
      allow update: if isOwner(uid)
                    || isSuperadmin()
                    || (hasPermission('users.approve')
                        && request.resource.data.diff(resource.data).affectedKeys()
                            .hasOnly(['membership', 'membershipRequestedAt', 'updatedAt']))
                    || (hasPermission('users.assign_roles')
                        && request.resource.data.diff(resource.data).affectedKeys()
                            .hasOnly(['roles', 'extraPermissions', 'updatedAt']));
      allow delete: if isSuperadmin();
    }

    // ── User notifications subcollection ──────────────────────────────────────
    match /users/{uid}/notifications/{notifId} {
      allow read: if isOwner(uid);
      allow update: if isOwner(uid);
      // Cloud Functions write via admin SDK (bypasses these rules)
    }

    // ── User FCM tokens subcollection ─────────────────────────────────────────
    match /users/{uid}/fcmTokens/{tokenId} {
      allow read: if isOwner(uid);
      allow write: if isOwner(uid);
      // Cloud Functions read via admin SDK
    }

    // ── Sermons ───────────────────────────────────────────────────────────────
    match /sermons/{id} {
      allow read: if true;
      allow write: if hasPermission('sermons.manage');
    }

    // ── Sermon Series ─────────────────────────────────────────────────────────
    match /series/{id} {
      allow read: if true;
      allow write: if hasPermission('sermons.manage');
    }

    // ── Events ────────────────────────────────────────────────────────────────
    match /events/{id} {
      allow read: if true;
      allow create, delete: if hasPermission('events.manage');
      // editors/admins can update any field; members can only add/remove their own UID from rsvps
      allow update: if hasPermission('events.manage')
                    || (isMember()
                        && request.resource.data.diff(resource.data).affectedKeys()
                            .hasOnly(['rsvps']));
    }

    // ── Blog ──────────────────────────────────────────────────────────────────
    match /blog/{id} {
      allow read: if true;
      allow write: if hasPermission('blog.manage');
    }

    // ── Leadership Team ───────────────────────────────────────────────────────
    match /team/{id} {
      allow read: if true;
      allow write: if hasPermission('team.manage');
    }

    // ── Gallery ───────────────────────────────────────────────────────────────
    match /gallery/{id} {
      allow read: if resource.data.audience == 'public' || isMember();
      allow write: if hasPermission('gallery.manage');
    }

    // ── Music ─────────────────────────────────────────────────────────────────
    match /music/{id} {
      allow read: if true;
      allow write: if hasPermission('music.manage');
    }

    // ── Prayer Requests ───────────────────────────────────────────────────────
    match /prayer/{id} {
      allow read: if isMember();
      // Author UID must match the signed-in member — prevents authorship spoofing
      allow create: if isMember() && request.resource.data.uid == request.auth.uid;
      // Author may update status/testimony/prayedFor; any member may toggle only
      // the prayedFor field (the "Praying" button); moderators may update any field.
      allow update: if hasPermission('prayer.moderate')
                    || (isOwner(resource.data.uid)
                        && request.resource.data.diff(resource.data).affectedKeys()
                            .hasOnly(['status', 'testimony', 'prayedFor']))
                    || (isMember()
                        && request.resource.data.diff(resource.data).affectedKeys()
                            .hasOnly(['prayedFor']));
      // Moderators delete any request; authors may delete their own.
      allow delete: if hasPermission('prayer.moderate') || isOwner(resource.data.uid);
    }

    // ── Groups ────────────────────────────────────────────────────────────────
    match /groups/{id} {
      allow read: if isMember();
      allow create: if hasPermission('groups.manage');
      allow update: if hasPermission('groups.manage') ||
        // Group leaders can manage their own group's members/pendingMembers
        (isSignedIn() && request.auth.uid in resource.data.leaders &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['members', 'pendingMembers'])) ||
        // Members can join/leave (add/remove their own UID from members or pendingMembers)
        (isMember() &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['members', 'pendingMembers']));
      allow delete: if isSuperadmin();
    }

    // ── Devotionals ───────────────────────────────────────────────────────────
    match /devotionals/{id} {
      allow read: if isMember();
      allow write: if hasPermission('devotional.manage');
    }

    // ── Notifications ─────────────────────────────────────────────────────────
    // Global /notifications collection is the admin broadcast history panel only.
    // Per-user inboxes live in /users/{uid}/notifications/ with their own rule.
    // audience-based field checks cannot gate collection queries in Firestore,
    // so we gate the whole collection on the permission that can also write it.
    match /notifications/{id} {
      allow read: if hasPermission('notifications.send');
      allow write: if hasPermission('notifications.send');
    }

    // ── Connect Forms ─────────────────────────────────────────────────────────
    match /connect/{id} {
      // Public, unauthenticated write surface — validate shape and bound sizes
      // to limit abuse. A submission cannot pre-mark itself as read.
      allow create: if request.resource.data.keys()
                          .hasOnly(['name', 'email', 'phone', 'message', 'read', 'submittedAt'])
                    && request.resource.data.name is string
                    && request.resource.data.name.size() > 0
                    && request.resource.data.name.size() <= 200
                    && request.resource.data.email is string
                    && request.resource.data.email.size() <= 200
                    && request.resource.data.message is string
                    && request.resource.data.message.size() > 0
                    && request.resource.data.message.size() <= 5000
                    && request.resource.data.read == false;
      allow read: if hasPermission('connect.view');
      allow update: if hasPermission('connect.view');
      allow delete: if hasPermission('connect.view');
    }

    // ── Roles (Phase 6) ───────────────────────────────────────────────────────
    match /roles/{roleId} {
      allow read: if isSignedIn();
      allow create, update: if isSuperadmin();
      allow delete: if isSuperadmin() && resource.data.isSystem != true;
    }

    // ── Site Config (Phase 8) ─────────────────────────────────────────────────
    // /config/{document} holds runtime site settings: church info, branding,
    // feature flags, notification routing. Written only by superadmins.
    match /config/{document} {
      // 'pages' is publicly readable — section order is not sensitive
      allow read: if isSignedIn() || document == 'pages';
      allow write: if isSuperadmin();
    }

    // ── Homepage ──────────────────────────────────────────────────────────────
    match /homepage/{id} {
      allow read: if true;
      allow write: if hasPermission('homepage.manage');
    }

    // ── Cottage Meetings (Phase 1) ──────────────────────────────────────────────
    // Member-visible meetings hosted by deacons (cottage.manage). The region list
    // lives in /config/cottageRegions (superadmin-managed via the existing rule).
    match /cottageMeetings/{meetingId} {
      allow read: if isMember();
      allow create: if isSuperadmin()
                    || (hasPermission('cottage.manage')
                        && request.resource.data.hostUid == request.auth.uid);
      allow update, delete: if isSuperadmin()
                    || (hasPermission('cottage.manage') && resource.data.hostUid == request.auth.uid);
    }

    // Registrations are keyed by member UID (one active registration per member)
    // and written ONLY by the registerForCottageMeeting / cancelCottageRegistration
    // Cloud Functions, which enforce capacity transactionally.
    match /cottageRegistrations/{regUid} {
      allow read: if isOwner(regUid)
                  || isSuperadmin()
                  || (hasPermission('cottage.manage')
                      && get(/databases/$(database)/documents/cottageMeetings/$(resource.data.meetingId)).data.hostUid == request.auth.uid);
      // create/update go only through the Cloud Functions (transactional seat
      // counting). delete is allowed for a meeting's host/superadmin so deleting
      // a meeting can clean up its registrations; members cancel via the function.
      allow create, update: if false;
      allow delete: if isSuperadmin()
                    || (hasPermission('cottage.manage')
                        && get(/databases/$(database)/documents/cottageMeetings/$(resource.data.meetingId)).data.hostUid == request.auth.uid);
    }

    // ── Messages (legacy flat collection — kept for backwards compat) ─────────
    match /messages/{id} {
      allow read: if isSignedIn() &&
        request.auth.uid in resource.data.participants;
      allow create: if isMember();
      allow update: if false;
      allow delete: if false;
    }

    // ── Conversations (direct messaging) ──────────────────────────────────────
    match /conversations/{convId} {
      allow read: if isSignedIn() &&
        request.auth.uid in resource.data.participants;
      allow create: if isMember();
      allow update: if isSignedIn() &&
        request.auth.uid in resource.data.participants &&
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['participants']);
      allow delete: if false;

      match /messages/{msgId} {
        allow read: if isSignedIn() &&
          request.auth.uid in
            get(/databases/$(database)/documents/conversations/$(convId)).data.participants;
        allow create: if isMember() &&
          request.auth.uid in
            get(/databases/$(database)/documents/conversations/$(convId)).data.participants;
        allow update: if false;
        allow delete: if false;
      }
    }
  }
}
