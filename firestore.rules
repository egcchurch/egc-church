rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helpers ──────────────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isMember() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.membership == 'member';
    }

    // Permission checks use Firebase Auth custom claims set by syncUserClaims.
    function isSuperadmin() {
      return request.auth != null && request.auth.token.superadmin == true;
    }

    function hasPermission(p) {
      return isSuperadmin() ||
             (request.auth != null &&
              request.auth.token.perms is list &&
              p in request.auth.token.perms);
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    // Returns true if the current user is a leader of the group linked to convId.
    // Used to gate leader-only delete on group chat messages.
    function isGroupLeaderOfConversation(convId) {
      let conv = get(/databases/$(database)/documents/conversations/$(convId)).data;
      return conv.type == 'group' &&
        'groupId' in conv &&
        conv.groupId != null &&
        request.auth.uid in
          get(/databases/$(database)/documents/groups/$(conv.groupId)).data.get('leaders', []);
    }

    // Returns true if the current user is allowed to post a message to convId.
    // Participant check is included so the caller only needs this one call.
    // For group chats with chatMode == "leaders_only", restricts posting to leaders.
    // Uses || short-circuit: group doc is only read when the conversation is a
    // group chat with a groupId. Firestore memoizes get() per request, so the
    // two references to the group doc below cost at most one read.
    function canPostToConversation(convId) {
      let conv = get(/databases/$(database)/documents/conversations/$(convId)).data;
      return (request.auth.uid in conv.participants) &&
        (conv.type != 'group' ||
         !('groupId' in conv) ||
         conv.groupId == null ||
         get(/databases/$(database)/documents/groups/$(conv.groupId)).data.get('chatMode', 'open') != 'leaders_only' ||
         request.auth.uid in get(/databases/$(database)/documents/groups/$(conv.groupId)).data.get('leaders', []));
    }

    // ── Users ─────────────────────────────────────────────────────────────────
    match /users/{uid} {
      allow read: if isOwner(uid) || isSuperadmin() || hasPermission('users.approve')
                  || (isMember() && resource.data.directoryVisible == true);
      // Self-provisioning (client create-if-missing on first sign-in) is locked to
      // safe defaults so a user can never create themselves as a member/superadmin.
      // The onUserCreate Cloud Function uses the Admin SDK and bypasses this.
      allow create: if isOwner(uid)
                    && request.resource.data.membership == 'pending'
                    && request.resource.data.isSuperadmin == false
                    && (!('roles' in request.resource.data)
                        || request.resource.data.roles.size() == 0)
                    && (!('extraPermissions' in request.resource.data)
                        || request.resource.data.extraPermissions.size() == 0);
      // isOwner: safe self-service fields only — no membership, roles, or isSuperadmin.
      // users.approve: membership tier on OTHER users only (not self).
      // users.assign_roles: roles/extraPermissions on OTHER users only (not self, not isSuperadmin).
      // isSuperadmin: unrestricted on any user.
      allow update: if isSuperadmin()
                    || (isOwner(uid)
                        && request.resource.data.diff(resource.data).affectedKeys()
                            .hasOnly(['displayName', 'photoURL', 'phone',
                                      'directoryVisible', 'directoryShowEmail', 'directoryShowPhone',
                                      'notifyWhatsApp', 'prayerNotifications', 'updatedAt']))
                    || (!isOwner(uid)
                        && hasPermission('users.approve')
                        && request.resource.data.diff(resource.data).affectedKeys()
                            .hasOnly(['membership', 'membershipRequestedAt', 'updatedAt']))
                    || (!isOwner(uid)
                        && hasPermission('users.assign_roles')
                        && request.resource.data.diff(resource.data).affectedKeys()
                            .hasOnly(['roles', 'extraPermissions', 'updatedAt']));
      allow delete: if isSuperadmin();
    }

    // ── User notifications subcollection ──────────────────────────────────────
    match /users/{uid}/notifications/{notifId} {
      allow read: if isOwner(uid);
      allow update: if isOwner(uid);
      allow delete: if isOwner(uid);
      // Cloud Functions write via admin SDK (bypasses these rules)
    }

    // ── User FCM tokens subcollection ─────────────────────────────────────────
    match /users/{uid}/fcmTokens/{tokenId} {
      allow read: if isOwner(uid);
      allow write: if isOwner(uid);
      // Cloud Functions read via admin SDK
    }

    // ── Sermons ───────────────────────────────────────────────────────────────
    match /sermons/{id} {
      allow read: if true;
      allow write: if hasPermission('sermons.manage');
    }

    // ── Sermon Series ─────────────────────────────────────────────────────────
    match /series/{id} {
      allow read: if true;
      allow write: if hasPermission('sermons.manage');
    }

    // ── Ignored YouTube imports ──────────────────────────────────────────────
    // Lets an admin permanently exclude a channel video (e.g. a funeral
    // service) from showing up in future bulk-import loads. Admin tool only —
    // no public read.
    match /ignoredYoutubeVideos/{youtubeId} {
      allow read, write: if hasPermission('sermons.manage');
    }

    // ── Events ────────────────────────────────────────────────────────────────
    match /events/{id} {
      allow read: if true;
      allow create, delete: if hasPermission('events.manage');
      // editors/admins can update any field; members can only add/remove their own UID from rsvps
      allow update: if hasPermission('events.manage')
                    || (isMember()
                        && request.resource.data.diff(resource.data).affectedKeys()
                            .hasOnly(['rsvps']));
    }

    // Event Registration (Phases B1-C2, see docs/EVENT_REGISTRATION.md) —
    // written ONLY by the registerForEvent / attachRegistrationProof /
    // setRegistrationStatus Cloud Functions, which enforce the public/members
    // audience gate, required-field validation, and (approve/decline)
    // capacity-seat accounting server-side (a public, possibly-
    // unauthenticated form can't be trusted to self-gate, and status changes
    // have to adjust seatsTaken transactionally, same reasoning as capacity
    // itself). Mirrors /cottageRegistrations exactly: create always goes
    // through a function; delete is available for admin cleanup. The one
    // direct client write allowed is an events.manage holder flipping
    // paymentConfirmed after checking the uploaded proof — a plain boolean
    // toggle with no business logic to enforce, unlike status or anything
    // else here.
    match /events/{eventId}/registrations/{id} {
      allow read: if hasPermission('events.manage');
      allow create: if false;
      allow update: if hasPermission('events.manage')
                    && request.resource.data.diff(resource.data).affectedKeys()
                        .hasOnly(['paymentConfirmed']);
      allow delete: if hasPermission('events.manage');
    }

    // ── Blog ──────────────────────────────────────────────────────────────────
    match /blog/{id} {
      allow read: if true;
      allow write: if hasPermission('blog.manage');
    }

    // ── Leadership Team ───────────────────────────────────────────────────────
    match /team/{id} {
      allow read: if true;
      allow write: if hasPermission('team.manage');
    }

    // ── Gallery ───────────────────────────────────────────────────────────────
    match /gallery/{id} {
      allow read: if resource.data.audience == 'public' || isMember();
      allow write: if hasPermission('gallery.manage');
    }

    // ── Music ─────────────────────────────────────────────────────────────────
    match /music/{id} {
      allow read: if true;
      allow write: if hasPermission('music.manage');
    }

    // ── Prayer Requests ───────────────────────────────────────────────────────
    match /prayer/{id} {
      // Moderators see everything.
      // Members see approved public requests (for community feed queries).
      // Members see their own requests at any approval state (for "My Requests" queries).
      allow read: if hasPermission('prayer.moderate')
                  || (isMember() && resource.data.approved == true && resource.data.isPrivate == false)
                  || (isMember() && resource.data.uid == request.auth.uid);
      // Author UID must match the signed-in member; new requests must start unapproved.
      allow create: if isMember()
                    && request.resource.data.uid == request.auth.uid
                    && request.resource.data.approved == false;
      // Author may update status/testimony/prayedFor; any member may toggle only
      // the prayedFor field (the "Praying" button); moderators may update any field.
      allow update: if hasPermission('prayer.moderate')
                    || (isOwner(resource.data.uid)
                        && request.resource.data.diff(resource.data).affectedKeys()
                            .hasOnly(['status', 'testimony', 'prayedFor']))
                    || (isMember()
                        && resource.data.approved == true
                        && request.resource.data.diff(resource.data).affectedKeys()
                            .hasOnly(['prayedFor']));
      // Moderators delete any request; authors may delete their own.
      allow delete: if hasPermission('prayer.moderate') || isOwner(resource.data.uid);
    }

    // ── Groups ────────────────────────────────────────────────────────────────
    match /groups/{id} {
      allow read: if isMember();
      allow create: if hasPermission('groups.manage');
      allow update: if hasPermission('groups.manage') ||
        // Group leaders can manage their own group's members/pendingMembers
        (isSignedIn() && request.auth.uid in resource.data.leaders &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['members', 'pendingMembers'])) ||
        // Members can join/leave (add/remove their own UID from members or pendingMembers)
        (isMember() &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['members', 'pendingMembers']));
      allow delete: if isSuperadmin();
    }

    // ── Serving Teams (rostered volunteer teams) ────────────────────────────────
    // Distinct from /groups: this is for teams that need scheduling (Equipment,
    // Worship, Youth Helpers), not standing fellowship groups. See docs/SERVING_TEAMS.md.
    function isServingTeamMember(teamId) {
      let team = get(/databases/$(database)/documents/servingTeams/$(teamId)).data;
      return isSignedIn() &&
        (request.auth.uid in team.members || request.auth.uid in team.leaders);
    }

    function isServingTeamLeader(teamId) {
      return isSignedIn() &&
        request.auth.uid in
          get(/databases/$(database)/documents/servingTeams/$(teamId)).data.leaders;
    }

    // A member can only claim a slot whose functions overlap with the functions a
    // leader has assigned them on the team (memberFunctions map). No entry for this
    // uid (the default for every existing member today) means locked out — a leader
    // must explicitly assign at least one function before that member can claim
    // anything. Leaders/admins bypass this entirely via the unrestricted branch above.
    function isQualifiedForFunctions(teamId, slotFunctions) {
      let team = get(/databases/$(database)/documents/servingTeams/$(teamId)).data;
      return ('memberFunctions' in team) &&
        (request.auth.uid in team.memberFunctions) &&
        slotFunctions.hasAny(team.memberFunctions[request.auth.uid]);
    }

    match /servingTeams/{teamId} {
      // Team existence/description is browsable by any member (to find/join a team);
      // the roster itself (slots, below) is scoped much more tightly.
      allow read: if isMember();
      allow create: if hasPermission('servingTeams.manage');
      allow update: if hasPermission('servingTeams.manage') ||
        // Leaders manage their own team's membership, tiers, function list, and
        // each member's function eligibility and availability (roster patterns
        // now live on named /schedules docs, not this field)
        (isSignedIn() && request.auth.uid in resource.data.leaders &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['members', 'pendingMembers', 'memberTiers', 'functions', 'memberFunctions', 'memberAvailability', 'updatedAt'])) ||
        // A team member can set their OWN availability (their life schedule is
        // theirs to declare) — but only their own key in the map, nobody else's.
        // Unlike memberFunctions (leader-only, an eligibility judgment), this is
        // self-service. get(..., {}) because older team docs lack the field.
        (isSignedIn() &&
          (request.auth.uid in resource.data.members || request.auth.uid in resource.data.leaders) &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['memberAvailability', 'updatedAt']) &&
          request.resource.data.get('memberAvailability', {})
            .diff(resource.data.get('memberAvailability', {}))
            .affectedKeys().hasOnly([request.auth.uid])) ||
        // Members can join/leave (add/remove their own UID) — same pattern as /groups
        (isMember() &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['members', 'pendingMembers']));
      allow delete: if hasPermission('servingTeams.manage');
    }

    match /servingTeams/{teamId}/slots/{slotId} {
      allow read: if hasPermission('servingTeams.manage') || isServingTeamMember(teamId);
      allow create: if hasPermission('servingTeams.manage') || isServingTeamLeader(teamId);
      allow delete: if hasPermission('servingTeams.manage') || isServingTeamLeader(teamId);
      // Leaders/admins can edit any field. A regular team member may only claim an
      // open lead or trainee position for THEMSELVES, or release their own —
      // never touch anyone else's assignment, the date, functions, or notes.
      allow update: if hasPermission('servingTeams.manage') || isServingTeamLeader(teamId) ||
        (isServingTeamMember(teamId) &&
          resource.data.assignedUid == null &&
          isQualifiedForFunctions(teamId, resource.data.functions) &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['assignedUid', 'assignedName', 'status', 'updatedAt']) &&
          request.resource.data.assignedUid == request.auth.uid) ||
        (isServingTeamMember(teamId) &&
          resource.data.assignedUid == request.auth.uid &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['assignedUid', 'assignedName', 'status', 'updatedAt']) &&
          request.resource.data.assignedUid == null) ||
        (isServingTeamMember(teamId) &&
          resource.data.traineeUid == null &&
          isQualifiedForFunctions(teamId, resource.data.functions) &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['traineeUid', 'traineeName', 'updatedAt']) &&
          request.resource.data.traineeUid == request.auth.uid) ||
        (isServingTeamMember(teamId) &&
          resource.data.traineeUid == request.auth.uid &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['traineeUid', 'traineeName', 'updatedAt']) &&
          request.resource.data.traineeUid == null);
    }

    // Named, reusable recurrence definitions (e.g. "EGC Elands") that bulk-create
    // slots across a date range and can be edited + regenerated as one action.
    // No member-self-service branch — only leaders/admins ever touch these.
    match /servingTeams/{teamId}/schedules/{scheduleId} {
      allow read: if hasPermission('servingTeams.manage') || isServingTeamMember(teamId);
      allow create, update, delete: if hasPermission('servingTeams.manage') || isServingTeamLeader(teamId);
    }

    // ── Equipment Register + Moves (Phase 2, Session 195) ────────────────────
    // Not a booking calendar — tracks where a piece of equipment currently is,
    // kept accurate via a "move" (pick a destination + checklist, mark packed,
    // complete). See docs/SERVING_TEAMS.md. Available to any team (general-
    // purpose, like schedules/slots), though in practice only used by the
    // Equipment Team.
    match /servingTeams/{teamId}/equipment/{itemId} {
      allow read: if hasPermission('servingTeams.manage') || isServingTeamMember(teamId);
      allow create, delete: if hasPermission('servingTeams.manage') || isServingTeamLeader(teamId);
      // Full-field edits (name, cost, condition, photo, description) are a
      // leader/admin action. Any team member may additionally update ONLY the
      // location fields — this is what completing a move actually writes, and
      // any member can complete a move they (or a teammate) packed, not just
      // the team's leaders.
      allow update: if hasPermission('servingTeams.manage') || isServingTeamLeader(teamId) ||
        (isServingTeamMember(teamId) &&
          request.resource.data.diff(resource.data).affectedKeys()
            .hasOnly(['currentLocation', 'lastMovedAt', 'lastMovedBy', 'updatedAt']));
    }

    match /servingTeams/{teamId}/moves/{moveId} {
      allow read: if hasPermission('servingTeams.manage') || isServingTeamMember(teamId);
      // Any team member can start a move (they're the one physically packing)
      // and update it (checking off items, marking complete) — a collaborative
      // checklist, not a leader-gated approval flow.
      allow create, update: if hasPermission('servingTeams.manage') || isServingTeamMember(teamId);
      allow delete: if hasPermission('servingTeams.manage') || isServingTeamLeader(teamId) ||
        (isServingTeamMember(teamId) && resource.data.createdBy == request.auth.uid);
    }

    // ── Devotionals ───────────────────────────────────────────────────────────
    match /devotionals/{id} {
      allow read: if isMember();
      allow write: if hasPermission('devotional.manage');
    }

    // ── Notifications ─────────────────────────────────────────────────────────
    // Global /notifications collection is the admin broadcast history panel only.
    // Per-user inboxes live in /users/{uid}/notifications/ with their own rule.
    // audience-based field checks cannot gate collection queries in Firestore,
    // so we gate the whole collection on the permission that can also write it.
    match /notifications/{id} {
      allow read: if hasPermission('notifications.send');
      allow write: if hasPermission('notifications.send');
    }

    // ── Connect Forms ─────────────────────────────────────────────────────────
    match /connect/{id} {
      // Public, unauthenticated write surface — validate shape and bound sizes
      // to limit abuse. A submission cannot pre-mark itself as read.
      allow create: if request.resource.data.keys()
                          .hasOnly(['name', 'email', 'phone', 'message', 'read', 'submittedAt'])
                    && request.resource.data.name is string
                    && request.resource.data.name.size() > 0
                    && request.resource.data.name.size() <= 200
                    && request.resource.data.email is string
                    && request.resource.data.email.size() <= 200
                    && request.resource.data.message is string
                    && request.resource.data.message.size() > 0
                    && request.resource.data.message.size() <= 5000
                    && request.resource.data.read == false;
      allow read: if hasPermission('connect.view');
      allow update: if hasPermission('connect.view');
      allow delete: if hasPermission('connect.view');
    }

    // ── Roles (Phase 6) ───────────────────────────────────────────────────────
    match /roles/{roleId} {
      allow read: if isSignedIn();
      allow create, update: if isSuperadmin();
      allow delete: if isSuperadmin() && resource.data.isSystem != true;
    }

    // ── Site Config (Phase 8) ─────────────────────────────────────────────────
    // /config/{document} holds runtime site settings: church info, branding,
    // feature flags, notification routing. Written only by superadmins.
    match /config/{document} {
      // 'pages' is publicly readable — section order is not sensitive.
      // 'emailCredentials' holds the raw SMTP username/password (Session 192) —
      // must never be readable OR writable by any client, even a superadmin's
      // browser session, as defense in depth against a rules bug or compromised
      // session. Only Cloud Functions (Admin SDK, which bypasses rules) touch
      // it, via updateEmailCredentials. Everything else on /config (including
      // the non-sensitive host/port/from fields on 'email') behaves as before.
      allow read: if document != 'emailCredentials' && (isSignedIn() || document == 'pages');
      allow write: if document != 'emailCredentials' && isSuperadmin();
    }

    // ── Site Media ───────────────────────────────────────────────────────────
    // General-purpose file manifest for /admin/media.html — lets a superadmin
    // upload arbitrary files (images/audio/documents) to Storage and find the
    // resulting URL again later, for use anywhere on the site (a page, a
    // download link, an admin field that takes a URL). Admin-only surface —
    // not read by any public page directly.
    match /siteMedia/{id} {
      allow read, write: if isSuperadmin();
    }

    // ── Homepage ──────────────────────────────────────────────────────────────
    match /homepage/{id} {
      allow read: if true;
      allow write: if hasPermission('homepage.manage');
    }

    // ── Cottage Meetings (Phase 1) ──────────────────────────────────────────────
    // Member-visible meetings hosted by deacons (cottage.manage). The region list
    // lives in /config/cottageRegions (superadmin-managed via the existing rule).
    match /cottageMeetings/{meetingId} {
      allow read: if isMember();
      allow create: if isSuperadmin()
                    || (hasPermission('cottage.manage')
                        && request.resource.data.hostUid == request.auth.uid);
      allow update, delete: if isSuperadmin()
                    || (hasPermission('cottage.manage') && resource.data.hostUid == request.auth.uid);
    }

    // Registrations are keyed by member UID (one active registration per member)
    // and written ONLY by the registerForCottageMeeting / cancelCottageRegistration
    // Cloud Functions, which enforce capacity transactionally.
    match /cottageRegistrations/{regUid} {
      allow read: if isOwner(regUid)
                  || isSuperadmin()
                  || (hasPermission('cottage.manage')
                      && get(/databases/$(database)/documents/cottageMeetings/$(resource.data.meetingId)).data.hostUid == request.auth.uid);
      // create/update go only through the Cloud Functions (transactional seat
      // counting). delete is allowed for a meeting's host/superadmin so deleting
      // a meeting can clean up its registrations; members cancel via the function.
      allow create, update: if false;
      allow delete: if isSuperadmin()
                    || (hasPermission('cottage.manage')
                        && get(/databases/$(database)/documents/cottageMeetings/$(resource.data.meetingId)).data.hostUid == request.auth.uid);
    }

    // ── Messages (legacy flat collection — kept for backwards compat) ─────────
    match /messages/{id} {
      allow read: if isSignedIn() &&
        request.auth.uid in resource.data.participants;
      allow create: if isMember();
      allow update: if false;
      allow delete: if false;
    }

    // ── Conversations (direct messaging) ──────────────────────────────────────
    match /conversations/{convId} {
      allow read: if isSignedIn() &&
        request.auth.uid in resource.data.participants;
      allow create: if isMember();
      allow update: if isSignedIn() &&
        request.auth.uid in resource.data.participants &&
        !request.resource.data.diff(resource.data).affectedKeys().hasAny(['participants']);
      allow delete: if false;

      match /messages/{msgId} {
        allow read: if isSignedIn() &&
          request.auth.uid in
            get(/databases/$(database)/documents/conversations/$(convId)).data.participants;
        // For group chats with chatMode == "leaders_only", only leaders may post.
        // canPostToConversation() reads the conversation once and the group once (if needed).
        allow create: if isMember() && canPostToConversation(convId);
        // Sender can correct their own message — body field only, adds editedAt timestamp.
        allow update: if isMember() &&
          request.auth.uid == resource.data.senderId &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly(['body', 'editedAt']);
        // Sender can delete their own message; group leaders can delete any message.
        allow delete: if isMember() && (
          request.auth.uid == resource.data.senderId ||
          isGroupLeaderOfConversation(convId)
        );
      }
    }
  }
}
