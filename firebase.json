{
  "hosting": [
    {
      "target": "staging",
      "public": ".",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**",
        "functions/**",
        "CLAUDE.md",
        "PROGRESS.md",
        "PROGRESS-archive.md",
        "ENVIRONMENT.md",
        "README.md",
        "SETUP.md",
        "setup.ps1",
        "setup.sh",
        "docs/**",
        "tests/**",
        "package.json",
        "package-lock.json"
      ],
      "redirects": [
        { "source": "/sermons", "destination": "/sermons.html", "type": 301 },
        { "source": "/events", "destination": "/events.html", "type": 301 },
        { "source": "/blog", "destination": "/blog.html", "type": 301 },
        { "source": "/about", "destination": "/about.html", "type": 301 },
        { "source": "/william-branham", "destination": "/william-branham.html", "type": 301 },
        { "source": "/fulfillment-of-prophecy", "destination": "/fulfillment-of-prophecy.html", "type": 301 },
        { "source": "/connect", "destination": "/connect.html", "type": 301 },
        { "source": "/gallery", "destination": "/gallery.html", "type": 301 },
        { "source": "/music", "destination": "/music.html", "type": 301 },
        { "source": "/login", "destination": "/login.html", "type": 301 },
        { "source": "/profile", "destination": "/profile.html", "type": 301 },
        { "source": "/contact", "destination": "/connect.html", "type": 301 },
        { "source": "/notice-board", "destination": "/events.html", "type": 301 },
        { "source": "/live-stream", "destination": "/members/live.html", "type": 301 }
      ],
      "rewrites": [
        { "source": "/feed.xml", "function": "podcastFeed" }
      ],
      "headers": [
        {
          "source": "/manifest.json",
          "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
        },
        {
          "source": "/service-worker.js",
          "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
        },
        {
          "source": "/js/**",
          "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
        },
        {
          "source": "/nav.html",
          "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
        },
        {
          "source": "/footer.html",
          "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
        },
        {
          "source": "/admin-nav.html",
          "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
        },
        {
          "source": "/members-nav.html",
          "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
        }
      ]
    },
    {
      "target": "production",
      "public": ".",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**",
        "functions/**",
        "CLAUDE.md",
        "PROGRESS.md",
        "PROGRESS-archive.md",
        "ENVIRONMENT.md",
        "README.md",
        "SETUP.md",
        "setup.ps1",
        "setup.sh",
        "docs/**",
        "tests/**",
        "package.json",
        "package-lock.json"
      ],
      "redirects": [
        { "source": "/sermons", "destination": "/sermons.html", "type": 301 },
        { "source": "/events", "destination": "/events.html", "type": 301 },
        { "source": "/blog", "destination": "/blog.html", "type": 301 },
        { "source": "/about", "destination": "/about.html", "type": 301 },
        { "source": "/william-branham", "destination": "/william-branham.html", "type": 301 },
        { "source": "/fulfillment-of-prophecy", "destination": "/fulfillment-of-prophecy.html", "type": 301 },
        { "source": "/connect", "destination": "/connect.html", "type": 301 },
        { "source": "/gallery", "destination": "/gallery.html", "type": 301 },
        { "source": "/music", "destination": "/music.html", "type": 301 },
        { "source": "/login", "destination": "/login.html", "type": 301 },
        { "source": "/profile", "destination": "/profile.html", "type": 301 },
        { "source": "/contact", "destination": "/connect.html", "type": 301 },
        { "source": "/notice-board", "destination": "/events.html", "type": 301 },
        { "source": "/live-stream", "destination": "/members/live.html", "type": 301 }
      ],
      "rewrites": [
        { "source": "/feed.xml", "function": "podcastFeed" }
      ],
      "headers": [
        {
          "source": "/manifest.json",
          "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
        },
        {
          "source": "/service-worker.js",
          "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
        },
        {
          "source": "/js/**",
          "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
        },
        {
          "source": "/nav.html",
          "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
        },
        {
          "source": "/footer.html",
          "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
        },
        {
          "source": "/admin-nav.html",
          "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
        },
        {
          "source": "/members-nav.html",
          "headers": [{ "key": "Cache-Control", "value": "no-cache" }]
        }
      ]
    }
  ],
  "firestore": {
    "database": "(default)",
    "location": "nam5",
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ]
    }
  ]
}
