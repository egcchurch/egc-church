{
  "hosting": [
    {
      "target": "staging",
      "public": ".",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**",
        "functions/**",
        "CLAUDE.md",
        "PROGRESS.md",
        "ENVIRONMENT.md",
        "README.md"
      ]
    },
    {
      "target": "production",
      "public": ".",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**",
        "functions/**",
        "CLAUDE.md",
        "PROGRESS.md",
        "ENVIRONMENT.md",
        "README.md"
      ]
    }
  ],
  "firestore": {
    "database": "(default)",
    "location": "nam5",
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  }
}
